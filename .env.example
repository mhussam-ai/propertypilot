# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Bolna ---
# Per-tenant API keys are stored encrypted in tenant_secrets. This is the platform-level fallback
# used by the seed script and admin tooling only.
BOLNA_PLATFORM_API_KEY=
BOLNA_API_BASE_URL=https://api.bolna.ai
# Bolna webhook source IP (https://www.bolna.ai/docs/polling-call-status-webhooks#ip-whitelist).
BOLNA_WEBHOOK_SOURCE_IPS=13.203.39.153

# --- Crypto ---
# 32-byte base64-encoded AES-256-GCM key used to wrap tenant secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KMS_KEY_B64=

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@propertypilot.in

# --- App ---
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development

# --- Sentry (error tracking + APM) ---
# Leave blank locally to keep Sentry inert. Set on Vercel/CI to enable.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only; used for source-map upload. Set in CI/Vercel secrets, NEVER commit.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
